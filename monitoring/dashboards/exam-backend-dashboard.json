{
  "title": "Exam Platform - Backend Dashboard",
  "uid": "exam-backend-dash",
  "timezone": "browser",
  "schemaVersion": 39,
  "panels": [
    {
      "type": "timeseries",
      "title": "Pod CPU Usage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"exam-platform\", pod=~\"exam-backend.*\"}[5m])) by (pod)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pod Memory Usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"exam-platform\", pod=~\"exam-backend.*\"}) by (pod)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"exam-platform\"}[5m])) by (status_code)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Running Pods",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=\"exam-platform\", phase=\"Running\", pod=~\"exam-backend.*\"})"
        }
      ]
    }
  ]
}
